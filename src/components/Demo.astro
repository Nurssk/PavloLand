---
---

<section class="demo" id="demo" data-screen-label="Demo" aria-label="PavloDAR AI demo video">
  <video
    class="demo-video"
    src="/pvldemo.mp4"
    autoplay
    muted
    loop
    playsinline
    controls
    preload="metadata"
  ></video>
</section>

<style>
  .demo {
    width: 100%;
    padding: 56px 24px;
    background: #000;
    display: grid;
    place-items: center;
  }

  .demo-video {
    display: block;
    width: min(100%, 760px);
    height: auto;
    object-fit: contain;
    background: #000;
  }

  @media (max-width: 720px) {
    .demo { padding: 42px 16px; }
  }
</style>
