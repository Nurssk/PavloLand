---
const menuLinks = [
  { label: 'Home', href: '#top' },
  { label: 'How it works', href: '#how' },
  { label: 'Demo', href: '#demo' },
  { label: 'Trust', href: '#trust' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];

const socialLinks = ['Instagram', 'LinkedIn', 'TikTok'];

const resourceLinks = ['Privacy policy', 'Aura terms', 'Fictional methodology'];
---

<footer class="footer" id="footer">
  <div class="footer-grid">
    <div class="footer-left">
      <section class="footer-cell">
        <h2>Menu</h2>
        <nav aria-label="Footer menu">
          {menuLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>
      </section>

      <section class="footer-cell">
        <h2>Connect</h2>
        <nav aria-label="Social links">
          {socialLinks.map((label) => (
            <a href="#top">{label}</a>
          ))}
        </nav>
      </section>

      <section class="footer-cell footer-resource">
        <h2>Resources</h2>
        <nav aria-label="Footer resources">
          {resourceLinks.map((label) => (
            <a href="#faq">{label}</a>
          ))}
        </nav>
        <p>Aura fiction by PavloDAR AI</p>
      </section>

      <section class="footer-cell">
        <h2>Contact</h2>
        <div class="footer-copy">
          <span>HELLO@PAVLODAR.AI</span>
          <span>KZ: +7 (7182) 00-00-00</span>
          <span>US: +1 (555) PVL-AURA</span>
        </div>
      </section>
    </div>

    <section class="footer-form-panel" aria-labelledby="footer-form-title">
      <h2 id="footer-form-title">Send us a message</h2>
      <form class="footer-form" data-footer-form>
        <label class="field">
          <span>First name *</span>
          <input name="first-name" autocomplete="given-name" required />
        </label>

        <label class="field">
          <span>Last name *</span>
          <input name="last-name" autocomplete="family-name" required />
        </label>

        <label class="field">
          <span>Email address *</span>
          <input type="email" name="email" autocomplete="email" required />
        </label>

        <label class="field">
          <span>Phone number</span>
          <input name="phone" autocomplete="tel" />
        </label>

        <label class="field field-full">
          <span>Message *</span>
          <textarea name="message" rows="4" required></textarea>
        </label>

        <div class="form-bottom">
          <span>*Required field</span>
          <button type="submit">Send message</button>
        </div>
      </form>
    </section>
  </div>

  <div class="footer-wordmark" aria-hidden="true">
    <div class="footer-brand">PAVLODAR</div>
    <div class="footer-surface"></div>
    <div class="footer-tagline">MEASURE THE AURA</div>
  </div>
</footer>

<script>
  const footerForm = document.querySelector('[data-footer-form]');
  footerForm?.addEventListener('submit', (event) => {
    event.preventDefault();
  });
</script>

<style>
  .footer {
    width: 100%;
    background: #000;
    color: #fff;
    border-top: 1px solid rgba(255, 255, 255, 0.42);
    overflow: hidden;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(440px, 1.04fr);
    min-height: 430px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.42);
  }

  .footer-left {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-right: 1px solid rgba(255, 255, 255, 0.42);
  }

  .footer-cell,
  .footer-form-panel {
    padding: 40px 42px;
  }

  .footer-cell {
    min-height: 215px;
    border-right: 1px solid rgba(255, 255, 255, 0.42);
    border-bottom: 1px solid rgba(255, 255, 255, 0.42);
  }

  .footer-cell:nth-child(2n) {
    border-right: 0;
  }

  .footer-cell:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .footer-cell h2,
  .footer-form-panel h2 {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.9);
  }

  .footer-cell nav,
  .footer-copy {
    display: grid;
    gap: 7px;
  }

  .footer-cell a,
  .footer-copy span,
  .footer-resource p {
    width: fit-content;
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    text-transform: uppercase;
    font-size: 12px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .footer-cell a {
    transition: color 0.15s ease;
  }

  .footer-cell a:hover {
    color: #fff;
  }

  .footer-resource {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .footer-form-panel {
    display: flex;
    flex-direction: column;
  }

  .footer-form {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px 32px;
    margin-top: 20px;
  }

  .field {
    display: grid;
    gap: 8px;
  }

  .field-full {
    grid-column: 1 / -1;
  }

  .field span,
  .form-bottom span {
    color: rgba(255, 255, 255, 0.76);
    font-size: 12px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .field input,
  .field textarea {
    width: 100%;
    border: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.44);
    border-radius: 0;
    background: transparent;
    color: #fff;
    font: inherit;
    font-size: 15px;
    outline: none;
  }

  .field input {
    height: 28px;
  }

  .field textarea {
    min-height: 96px;
    resize: vertical;
  }

  .field input:focus,
  .field textarea:focus {
    border-bottom-color: #fff;
  }

  .form-bottom {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .form-bottom button {
    min-height: 38px;
    padding: 0 18px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 0;
    background: transparent;
    color: #fff;
    font-size: 12px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .form-bottom button:hover {
    background: #fff;
    color: #000;
  }

  .footer-wordmark {
    position: relative;
    min-height: clamp(340px, 41vw, 610px);
    background: #000;
    overflow: hidden;
  }

  .footer-brand {
    position: absolute;
    left: 1.6vw;
    bottom: 142px;
    z-index: 1;
    color: #fff;
    font-family: var(--font-wordmark);
    font-size: clamp(150px, 24vw, 470px);
    font-style: italic;
    font-weight: 400;
    line-height: 0.72;
    letter-spacing: 0;
    white-space: nowrap;
    transform: skewX(-6deg);
  }

  .footer-surface {
    position: absolute;
    right: -14vw;
    bottom: -28%;
    z-index: 2;
    width: min(860px, 56vw);
    aspect-ratio: 1.75 / 1;
    transform: rotate(-7deg) skewX(-18deg);
    border-radius: 52% 48% 0 0;
    background:
      repeating-radial-gradient(ellipse at 50% 78%, rgba(255, 255, 255, 0.95) 0 2px, rgba(255, 255, 255, 0) 3px 22px),
      linear-gradient(118deg, #050505 0%, #111 32%, #f6f6f6 47%, #090909 55%, #2f2f2f 71%, #fff 82%, #080808 100%);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.28),
      inset -90px 34px 80px rgba(0, 0, 0, 0.72),
      0 -16px 34px rgba(255, 255, 255, 0.18);
    opacity: 0.88;
    pointer-events: none;
  }

  .footer-tagline {
    position: absolute;
    left: 42px;
    bottom: 24px;
    z-index: 3;
    color: rgba(255, 255, 255, 0.92);
    font-size: clamp(28px, 3vw, 54px);
    line-height: 0.9;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-left {
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.42);
    }

    .footer-form {
      gap: 22px;
    }
  }

  @media (max-width: 640px) {
    .footer-left,
    .footer-form {
      grid-template-columns: 1fr;
    }

    .footer-cell,
    .footer-form-panel {
      padding: 30px 24px;
    }

    .footer-cell,
    .footer-cell:nth-child(2n),
    .footer-cell:nth-last-child(-n + 2) {
      min-height: auto;
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.42);
    }

    .footer-cell:last-child {
      border-bottom: 0;
    }

    .footer-form {
      margin-top: 18px;
    }

    .form-bottom {
      align-items: flex-start;
      flex-direction: column;
    }

    .form-bottom button {
      width: 100%;
    }

    .footer-wordmark {
      min-height: 320px;
    }

    .footer-brand {
      left: 22px;
      bottom: 158px;
      font-size: clamp(94px, 28vw, 150px);
    }

    .footer-surface {
      right: -42vw;
      width: 92vw;
      bottom: -16%;
    }

    .footer-tagline {
      left: 24px;
      bottom: 26px;
    }
  }
</style>
